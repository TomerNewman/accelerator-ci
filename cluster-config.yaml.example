# Accelerator CI — cluster configuration
#
# Only cluster_name and ocp_version are required.
# For BYOC (--kubeconfig), that's all you need.
# For kcli deploy, also set domain, pull_secret_path, and api_ip.

# --- Required ---

cluster_name: ocp
ocp_version: "4.17"

# --- Required for deploy (not needed for --kubeconfig) ---

domain: lab.local                    # must not be "example.com"
pull_secret_path: ~/keys/pull-secret.json
api_ip: "192.168.122.253"

# --- Cluster topology ---

ctlplanes: 1                         # 1 control plane + 0 workers = SNO
workers: 0

ctlplane:
  numcpus: 8
  memory: 24576                      # MB

worker:
  numcpus: 4
  memory: 16384                      # MB

disk_size: 120                       # GB
network: default
version_channel: stable
wait_timeout: 3600                   # seconds

# --- Remote deployment (null = local) ---

remote:
  host: null                         # set to deploy on a remote libvirt host
  user: root
  ssh_key_path: null                 # e.g. ~/.ssh/id_rsa

# --- PCI passthrough ---

pci_devices: []
# pci_devices: [0000:41:00.0, 0000:42:00.0]

# --- Operators ---
# machine_config_role is "worker" by default; auto-set to "master" for SNO.
# All other fields are vendor-specific and passed to the VendorProfile as a dict.

operators:
  machine_config_role: worker
  # gpu_operator_version: "24.3.0"
  # driver_version: "550.127"

# --- Must-gather ---

must_gather:
  artifact_dir: ./must-gather-output

# --- Informational ---

vendor: ""                           # label only; actual profile loaded via --vendor-module
